# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
MONGODB_URI=mongodb://newsaccess:newsaccess123@mongodb:27017/newsaccess?authSource=admin
MONGODB_USER=newsaccess
MONGODB_PASSWORD=changeme
MONGODB_ROOT_PASSWORD=admin123

# Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Publisher API Keys
NYT_API_KEY=your_nyt_api_key
FT_API_KEY=your_ft_api_key
WSJ_API_KEY=your_wsj_api_key
WAPO_API_KEY=your_wapo_api_key

# CORS
CORS_ORIGIN=http://localhost:8080,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

# Frontend URL
FRONTEND_URL=http://localhost:8080